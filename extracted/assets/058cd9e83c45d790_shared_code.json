nter justify-between mb-8 border-b border-slate-100 pb-4\">\n                            <span class=\"text-sm font-medium text-slate-500\">Estimated Value</span>\n                            <span class=\"text-2xl font-semibold text-slate-900\">₹4,000 - ₹30,000</span>\n                        </div>\n                        <div class=\"space-y-6\">\n                            <div class=\"\">\n                                <label class=\"block text-xs font-medium text-slate-700 mb-2\">Condition</label>\n                                <div class=\"grid grid-cols-3 gap-2\">\n                                    <button class=\"px-4 py-2 rounded-lg border border-slate-200 text-xs font-medium hover:border-blue-500 hover:text-blue-600 hover:bg-blue-50 transition-colors focus:ring-2 ring-blue-500 ring-offset-1\">Broken</button>\n                                    <button class=\"px-4 py-2 rounded-lg border-2 border-blue-500 bg-blue-50 text-blue-700 text-xs font-medium\">Used</button>\n                                    <button class=\"px-4 py-2 rounded-lg border border-slate-200 text-xs font-medium hover:border-blue-500 hover:text-blue-600 hover:bg-blue-50 transition-colors\">Like New</button>\n                                </div>\n                            </div>\n                            <div class=\"\">\n                                <label class=\"block text-xs font-medium text-slate-700 mb-2\">Age of Unit (Years)</label>\n                                <input type=\"range\" min=\"1\" max=\"15\" value=\"4\" class=\"w-full\">\n                                <div class=\"flex justify-between text-xs text-slate-400 mt-2\">\n                                    <span>1 Year</span>\n                                    <span>15+ Years</span>\n                                </div>\n                            </div>\n                            <div class=\"pt-4\">\n                                <button class=\"w-full py-3 bg-slate-900 text-white text-sm font-medium rounded-lg hover:bg-slate-800 transition-colors shadow-lg shadow-slate-900/10\">\n                                    Request Evaluation\n                                </button>\n                            </div>\n                        </div>\n                    </div>\n                </div>\n            </div>\n        </div>\n    </section>\n\n    <!-- Contact / Booking Section -->\n    <section id=\"contact\" class=\"py-24 bg-slate-50 border-t border-slate-200\">\n        <div class=\"max-w-3xl mx-auto px-4 sm:px-6 lg:px-8\">\n            <div class=\"text-center mb-12\">\n                <h2 class=\"text-3xl font-semibold text-slate-900 tracking-tight\">Get in touch</h2>\n                <p class=\"mt-3 text-slate-500\">Book a service or sell your unit. We'll get back to you within 2 hours.</p>\n            </div>\n\n            <form class=\"bg-white p-8 sm:p-12 rounded-2xl border border-slate-200 shadow-sm\">\n                <div class=\"grid grid-cols-1 gap-y-6 gap-x-8 sm:grid-cols-2\">\n                    \n                    <!-- Intent Selection -->\n                    <div class=\"sm:col-span-2\">\n                        <label class=\"block text-xs font-medium text-slate-700 mb-3\">I want to...</label>\n                        <div class=\"flex gap-4\">\n                            <label class=\"flex items-center gap-2 cursor-pointer group\">\n                                <input type=\"radio\" name=\"intent\" class=\"sr-only peer\" checked=\"\">\n                                <span class=\"w-4 h-4 rounded-full border border-slate-300 peer-checked:border-blue-500 peer-checked:border-4 transition-all\"></span>\n                                <span class=\"text-sm text-slate-600 group-hover:text-slate-900\">Book Service</span>\n                            </label>\n                            <label class=\"flex items-center gap-2 cursor-pointer group\">\n                                <input type=\"radio\" name=\"intent\" class=\"sr-only peer\">\n                                <span class=\"w-4 h-4 rounded-full border border-slate-300 peer-checked:border-blue-500 peer-checked:border-4 transition-all\"></span>\n                                <span class=\"text-sm text-slate-600 group-hover:text-slate-900\">Sell My AC</span>\n                            </label>\n                        </div>\n                    </div>\n\n                    <div class=\"sm:col-span-2\">\n                        <label for=\"name\" class=\"block text-xs font-medium text-slate-700 mb-1\">Full Name</label>\n                        <input type=\"text\" name=\"name\" class=\"block placeholder-slate-400 focus:border-blue-500 focus:bg-white focus:ring-1 focus:ring-blue-500 outline-none transition-all text-sm text-slate-900 bg-slate-50 w-full border-slate-200 rounded-lg pt-3 pr-4 pb-3 pl-4\" placeholder=\"Kasim Shaikh\" id=\"name\">\n                    </div>\n\n                    <div class=\"\">\n                        <label for=\"phone\" class=\"block text-xs font-medium text-slate-700 mb-1\">Phone Number</label>\n                        <input type=\"tel\" name=\"phone\" id=\"phone\" class=\"block w-full rounded-lg border-slate-200 bg-slate-50 px-4 py-3 text-sm text-slate-900 placeholder-slate-400 focus:border-blue-500 focus:bg-white focus:ring-1 focus:ring-blue-500 outline-none transition-all\" placeholder=\"+91 9998270432\">\n                    </div>\n\n                    <div class=\"\">\n                        <label for=\"email\" class=\"block text-xs font-medium text-slate-700 mb-1\">Email</label>\n                        <input type=\"email\" name=\"email\" id=\"email\" class=\"block w-full rounded-lg border-slate-200 bg-slate-50 px-4 py-3 text-sm text-slate-900 placeholder-slate-400 focus:border-blue-500 focus:bg-white focus:ring-1 focus:ring-blue-500 outline-none transition-all\" placeholder=\"kasimshaikh786@com\">\n                    </div>\n\n                    <div class=\"sm:col-span-2\">\n                        <label for=\"message\" class=\"block text-xs font-medium text-slate-700 mb-1\">Details (Model, Issue, or Condition)</label>\n                        <textarea id=\"message\" name=\"message\" rows=\"4\" class=\"block w-full rounded-lg border-slate-200 bg-slate-50 px-4 py-3 text-sm text-slate-900 placeholder-slate-400 focus:border-blue-500 focus:bg-white focus:ring-1 focus:ring-blue-500 outline-none transition-all resize-none\" placeholder=\"Describe your request...\"></textarea>\n                    </div>\n\n                    <div class=\"sm:col-span-2 flex items-start gap-3\">\n                        <div class=\"flex h-5 items-center\">\n                            <input id=\"offers\" name=\"offers\" type=\"checkbox\" class=\"h-4 w-4 rounded border-slate-300 custom-checkbox focus:ring-blue-500\">\n                        </div>\n                        <div class=\"text-xs\">\n                            <label for=\"offers\" class=\"font-medium text-slate-700\">Get a callback ASAP</label>\n                            <p class=\"text-slate-500\">We will prioritize your request and call you immediately.</p>\n                        </div>\n                    </div>\n                </div>\n                <div class=\"mt-8\">\n                    <button type=\"submit\" class=\"w-full rounded-full bg-blue-600 px-4 py-3 text-sm font-medium text-white shadow-sm hover:bg-blue-500 focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-blue-600 transition-all flex items-center justify-center gap-2\">\n                        Submit Request\n                        <iconify-icon icon=\"solar:plain-2-linear\" class=\"text-lg\"></iconify-icon>\n                    </button>\n                </div>\n            </form>\n            \n            <div class=\"mt-12 flex justify-center gap-8 border-t border-slate-200 pt-8\">\n                <div class=\"flex items-center gap-2 text-slate-500\"